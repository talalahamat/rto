{
  "expo": {
    "name": "Rent To Own",
    "slug": "rto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "lk.andhholdings.renttoown"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "lk.andhholdings.renttoown"
    },
    "plugins": [
      "expo-font",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR-PROJECT-ID-HERE"
      }
    }
  }
}
